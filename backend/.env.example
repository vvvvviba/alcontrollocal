# LLM 配置（类 OpenAI 接口）
# 提示：也可以直接在网页“设置”里配置并保存到 backend/config.json（推荐）。

# OpenAI 示例
# OPENAI_API_KEY="sk-..."
# OPENAI_BASE_URL="https://api.openai.com/v1"
# LLM_MODEL="gpt-3.5-turbo"

# DeepSeek 示例
# OPENAI_API_KEY="sk-..."
# OPENAI_BASE_URL="https://api.deepseek.com"
# LLM_MODEL="deepseek-chat"

# Minimax 示例
# OPENAI_API_KEY="sk-..."
# OPENAI_BASE_URL="https://api.minimaxi.com/v1"
# LLM_MODEL="MiniMax-M2.5"

# 本地 Ollama 示例
# OPENAI_API_KEY="any"
# OPENAI_BASE_URL="http://localhost:11434/v1"
# LLM_MODEL="llama3"

# 共享文件夹（可选；也可在网页“设置 → 共享文件”里配置）
# AICONTROL_SHARED_DIR="D:/aicontrol/shared"
